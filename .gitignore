app/storage/images/*
!app/storage/images/.gitkeep
app/storage/optimized/*
!app/storage/optimized/.gitkeep
app/storage/thumbnails/*
!app/storage/thumbnails/.gitkeep

# Logs
logs/*
!logs/.gitkeep
*.log

