# Document & Image Service — environment configuration
# Copy this file to .env and update the values before going to production.

# Required: shared secret for the X-API-Key header on all protected endpoints
API_KEY=microfindev263

# Gunicorn / Uvicorn bind port (must match documents.service and Apache ProxyPass)
PORT=8000

# Maximum upload size (supports B, KB, MB, GB suffixes)
MAX_UPLOAD_SIZE=50MB

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
